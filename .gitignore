__pycache__/
.pytest_cache/
.venv/
*.pyc
*.pyo
*.pyd

# Generated artifacts
outputs/
analysis_outputs/
inference_outputs/
data/
dataset/
datasets/
src/models/external/

# Local dataset mounts outside the formal repo layout
*.zip

# Keep tracked placeholders if you decide to add them later
!outputs/.gitkeep
!outputs/**/.gitkeep

# Personal or machine-specific config overrides
configs/**/*local*.yaml
configs/**/*private*.yaml
configs/**/*secret*.yaml
configs/**/*override*.yaml
configs/**/*user*.yaml
configs/**/*machine*.yaml
*.env
*.env.*
